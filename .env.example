# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Postgres (Neon). Use the DIRECT connection string for Alembic migrations;
# the pooled (-pooler) endpoint is fine for app runtime. SSL is required.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-west-2.aws.neon.tech/neondb?sslmode=require

# Shared secret guarding POST /admin/sync. Must match the value set in the
# Render dashboard AND the GitHub Actions repo secret of the same name.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_AUTH_TOKEN=

# Your FPL Draft league id — the number in draft.premierleague.com/league/<ID>/...
FPL_DRAFT_LEAGUE_ID=

# Optional: overrides the FPL Draft API base (defaults to the public endpoint).
# FPL_API_BASE=https://draft.premierleague.com/api
